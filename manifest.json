{
  "manifest_version": 3,
  "name": "AutoFill — Smart Form Filler",
  "short_name": "AutoFill",
  "version": "1.0.0",
  "version_name": "1.0.0",
  "description": "Smart autofill for Google Forms. A self-learning Brain engine maps your saved info to any form field — no manual matching needed.",
  "author": "AutoFill",
  "homepage_url": "https://github.com/AutoFill-Extension",

  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://docs.google.com/forms/*"],

  "action": {
    "default_title": "AutoFill — Smart Form Filler",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/brain_worker.js"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html"],
      "matches": ["chrome-extension://*/*"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
  }
}
